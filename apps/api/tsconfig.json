{
  "extends": "@darbha/config/tsconfig/base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "outDir": "dist",
    "baseUrl": "./",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "incremental": true
  },
  "include": ["src"]
}
